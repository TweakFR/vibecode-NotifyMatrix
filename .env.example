# Copier vers .env à la racine du projet : cp .env.example .env
# Les valeurs sont injectées au build dans include/secrets_from_env.h (généré, gitignoré).

WIFI_SSID=
WIFI_PASSWORD=

MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TOPIC_NOTIFY=test/message

# PRIM / Île-de-France Mobilités (https://prim.iledefrance-mobilites.fr)
IDFM_API_KEY=
# Point d’arrêt SIRI : utiliser le préfixe STIF (l’API n’accepte pas IDFM:15352 tel quel).
# Ex. arrêt Paix Notre Dame (Lagny) : STIF:StopPoint:Q:15352:
IDFM_MONITORING_REF=STIF:StopPoint:Q:15352:
# LineRef STIF (recommandé) : filtre côté PRIM, moins de données sur l’ESP32.
# Ex. bus 2225 : STIF:Line::C00628: (route_id IDFM:C00628)
IDFM_LINE_REF=STIF:Line::C00628:
# Nom commercial / numéro affiché (ex. bus 2225)
IDFM_LINE_LABEL=2225
# Correspond au route_id interne (ex. IDFM:C00628 -> mettre C00628 pour matcher STIF:Line::C00628:)
IDFM_LINE_CODE=C00628
