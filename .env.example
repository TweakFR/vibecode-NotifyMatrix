# Copy this file to `.env`, then fill in local credentials:
#   cp .env.example .env
#
# PlatformIO reads `.env` at build time and injects these values as compiler defines.

WIFI_SSID=
WIFI_PASSWORD=

MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TOPIC_NOTIFY=notifymatrix/notify

# PRIM / Ile-de-France Mobilites
IDFM_API_KEY=

# ---------------------------------------------------------------------------
# Mode A: single line
# ---------------------------------------------------------------------------
# Keep IDFM_SLOT_COUNT=0 and set the single-line fields below.

IDFM_SLOT_COUNT=0
IDFM_MONITORING_REF=STIF:StopPoint:Q:15352:
IDFM_LINE_REF=STIF:Line::C00628:
IDFM_LINE_LABEL=2225
IDFM_LINE_CODE=C00628

# ---------------------------------------------------------------------------
# Mode B: carousel
# ---------------------------------------------------------------------------
# To enable the carousel, set IDFM_SLOT_COUNT to the number of slots and
# uncomment/fill the corresponding IDFM_SLOT_N_* entries. The current local
# carousel is provided below as an example.
#
# IDFM_SLOT_COUNT=8
#
# IDFM_SLOT_0_MONITORING_REF=STIF:StopPoint:Q:15352:
# IDFM_SLOT_0_LINE_REF=STIF:Line::C00628:
# IDFM_SLOT_0_LINE_CODE=C00628
# IDFM_SLOT_0_LABEL=2225
#
# IDFM_SLOT_1_MONITORING_REF=STIF:StopPoint:Q:15687:
# IDFM_SLOT_1_LINE_REF=STIF:Line::C00627:
# IDFM_SLOT_1_LINE_CODE=C00627
# IDFM_SLOT_1_LABEL=2223
#
# IDFM_SLOT_2_MONITORING_REF=STIF:StopPoint:Q:15687:
# IDFM_SLOT_2_LINE_REF=STIF:Line::C01879:
# IDFM_SLOT_2_LINE_CODE=C01879
# IDFM_SLOT_2_LABEL=2224
#
# IDFM_SLOT_3_MONITORING_REF=STIF:StopPoint:Q:15687:
# IDFM_SLOT_3_LINE_REF=STIF:Line::C01639:
# IDFM_SLOT_3_LINE_CODE=C01639
# IDFM_SLOT_3_LABEL=N141
#
# IDFM_SLOT_4_MONITORING_REF=STIF:StopPoint:Q:15687:
# IDFM_SLOT_4_LINE_REF=STIF:Line::C00625:
# IDFM_SLOT_4_LINE_CODE=C00625
# IDFM_SLOT_4_LABEL=2221
#
